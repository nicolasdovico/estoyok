{
    "openapi": "3.0.0",
    "info": {
        "title": "Estoy Ok API",
        "description": "API para la plataforma de seguridad familiar Estoy Ok",
        "contact": {
            "email": "soporte@estoyok.com"
        },
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "/api",
            "description": "Servidor API Principal"
        }
    ],
    "paths": {
        "/register": {
            "post": {
                "tags": [
                    "Autenticación"
                ],
                "summary": "Registrar un nuevo usuario",
                "operationId": "5d4fa5d5607ed675ba93907e1fc94534",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "name",
                                    "email",
                                    "password",
                                    "password_confirmation"
                                ],
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "Juan Pérez"
                                    },
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "juan@example.com"
                                    },
                                    "password": {
                                        "type": "string",
                                        "format": "password",
                                        "example": "secret123"
                                    },
                                    "password_confirmation": {
                                        "type": "string",
                                        "format": "password",
                                        "example": "secret123"
                                    },
                                    "phone": {
                                        "type": "string",
                                        "example": "+541122334455"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Usuario registrado. Se ha enviado un código de verificación al email.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Usuario registrado exitosamente. Por favor verifica tu email."
                                        },
                                        "email": {
                                            "type": "string",
                                            "example": "juan@example.com"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/verify-email": {
            "post": {
                "tags": [
                    "Autenticación"
                ],
                "summary": "Verificar email con código OTP",
                "operationId": "02076c23389c10136110c5fb053d8acc",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "email",
                                    "code"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "juan@example.com"
                                    },
                                    "code": {
                                        "type": "string",
                                        "example": "123456"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Email verificado correctamente",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "token": {
                                            "type": "string",
                                            "example": "1|abcde..."
                                        },
                                        "user": {
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Código inválido o expirado"
                    }
                }
            }
        },
        "/resend-otp": {
            "post": {
                "tags": [
                    "Autenticación"
                ],
                "summary": "Reenviar código OTP",
                "operationId": "5c5c7919f89a315f4249bc02ea5eae4c",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "email"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "juan@example.com"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Código reenviado"
                    }
                }
            }
        },
        "/login": {
            "post": {
                "tags": [
                    "Autenticación"
                ],
                "summary": "Iniciar sesión",
                "operationId": "67d6d0fdd54fba132e1b6f55ca254183",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "email",
                                    "password"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "juan@example.com"
                                    },
                                    "password": {
                                        "type": "string",
                                        "format": "password",
                                        "example": "secret123"
                                    },
                                    "device_name": {
                                        "type": "string",
                                        "example": "iPhone 15"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Login exitoso",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "token": {
                                            "type": "string",
                                            "example": "1|abcde..."
                                        },
                                        "user": {
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Credenciales inválidas"
                    }
                }
            }
        },
        "/logout": {
            "post": {
                "tags": [
                    "Autenticación"
                ],
                "summary": "Cerrar sesión",
                "operationId": "28d48c13fca984400ac8de99f54ee13a",
                "responses": {
                    "200": {
                        "description": "Sesión cerrada"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/check-in": {
            "post": {
                "tags": [
                    "Check-in"
                ],
                "summary": "Realizar check-in diario",
                "operationId": "ee57a7431caf3c03bc54120991be471c",
                "responses": {
                    "200": {
                        "description": "Check-in realizado exitosamente",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Check-in exitoso"
                                        },
                                        "last_check_in_at": {
                                            "type": "string",
                                            "format": "date-time"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/check-ins": {
            "get": {
                "tags": [
                    "Check-in"
                ],
                "summary": "Obtener el historial de check-ins del usuario",
                "operationId": "78bad792011621c407c78a3ffba5d2ac",
                "responses": {
                    "200": {
                        "description": "Historial de check-ins obtenido exitosamente",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "properties": {
                                            "id": {
                                                "type": "integer",
                                                "example": 1
                                            },
                                            "created_at": {
                                                "type": "string",
                                                "format": "date-time"
                                            }
                                        },
                                        "type": "object"
                                    }
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/emergency-contacts": {
            "get": {
                "tags": [
                    "Contactos de Emergencia"
                ],
                "summary": "Listar contactos de emergencia",
                "operationId": "50fa14d0ee417094cac749ac7966f7c1",
                "responses": {
                    "200": {
                        "description": "Lista de contactos"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            },
            "post": {
                "tags": [
                    "Contactos de Emergencia"
                ],
                "summary": "Crear contacto de emergencia",
                "operationId": "c0b2da6fd2a2b30cc15845d2cc7d4f95",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "name",
                                    "phone"
                                ],
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "Mamá"
                                    },
                                    "phone": {
                                        "type": "string",
                                        "example": "+541122334455"
                                    },
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "mama@example.com"
                                    },
                                    "relationship": {
                                        "type": "string",
                                        "example": "Madre"
                                    },
                                    "is_active": {
                                        "type": "boolean",
                                        "example": true
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Contacto creado"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/emergency-contacts/{id}": {
            "get": {
                "tags": [
                    "Contactos de Emergencia"
                ],
                "summary": "Obtener un contacto específico",
                "operationId": "7affa0aafa608edec718556b344846c8",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Datos del contacto"
                    },
                    "403": {
                        "description": "No autorizado"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            },
            "put": {
                "tags": [
                    "Contactos de Emergencia"
                ],
                "summary": "Actualizar contacto de emergencia",
                "operationId": "e4a7dca4f39b3b3e33ebede3e9cb8c18",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "name": {
                                        "type": "string"
                                    },
                                    "phone": {
                                        "type": "string"
                                    },
                                    "email": {
                                        "type": "string",
                                        "format": "email"
                                    },
                                    "relationship": {
                                        "type": "string"
                                    },
                                    "is_active": {
                                        "type": "boolean"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Contacto actualizado"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            },
            "delete": {
                "tags": [
                    "Contactos de Emergencia"
                ],
                "summary": "Eliminar contacto de emergencia",
                "operationId": "482b9cd15c738c718eef3c5b772643ba",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "204": {
                        "description": "Contacto eliminado"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/settings/checkin-interval": {
            "put": {
                "tags": [
                    "Configuración"
                ],
                "summary": "Actualizar intervalo de check-in",
                "operationId": "c31ec33668dde62fcaa6ade8b6aedf48",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "checkin_interval_hours"
                                ],
                                "properties": {
                                    "checkin_interval_hours": {
                                        "type": "integer",
                                        "example": 24,
                                        "maximum": 168,
                                        "minimum": 1
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Intervalo actualizado"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/settings/quiet-hours": {
            "put": {
                "tags": [
                    "Configuración"
                ],
                "summary": "Actualizar configuración de horas silenciosas",
                "operationId": "4956ddf94a4bf05809e44cdb2227e111",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "quiet_hours_enabled",
                                    "quiet_hours_start",
                                    "quiet_hours_end",
                                    "timezone"
                                ],
                                "properties": {
                                    "quiet_hours_enabled": {
                                        "type": "boolean",
                                        "example": true
                                    },
                                    "quiet_hours_start": {
                                        "type": "string",
                                        "example": "23:00"
                                    },
                                    "quiet_hours_end": {
                                        "type": "string",
                                        "example": "07:00"
                                    },
                                    "timezone": {
                                        "type": "string",
                                        "example": "America/Argentina/Buenos_Aires"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Configuración actualizada"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        }
    },
    "tags": [
        {
            "name": "Autenticación",
            "description": "Autenticación"
        },
        {
            "name": "Check-in",
            "description": "Check-in"
        },
        {
            "name": "Contactos de Emergencia",
            "description": "Contactos de Emergencia"
        },
        {
            "name": "Configuración",
            "description": "Configuración"
        }
    ],
    "components": {
        "securitySchemes": {
            "sanctum": {
                "type": "http",
                "scheme": "bearer",
                "description": "Enter token in format (Bearer <token>)",
                "name": "Authorization",
                "in": "header"
            }
        }
    },
    "security": [
        {
            "sanctum": []
        }
    ]
}